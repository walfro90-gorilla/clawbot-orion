# Copy this file to .env and fill in the values

# LinkedIn session cookie (grab from browser DevTools → Application → Cookies → linkedin.com)
LI_AT=your_li_at_value_here

# Google Gemini API key (console.cloud.google.com → APIs & Services → Credentials)
GEMINI_API_KEY=your_gemini_api_key_here

# Target LinkedIn profile URL to scrape (default: williamhgates)
TARGET_PROFILE=https://www.linkedin.com/in/williamhgates/

# Safety switch — true = only scrape+generate, never click buttons or send anything
# Set to false ONLY when ready for real outreach
DRY_RUN=true

# Supabase (for future phases)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
